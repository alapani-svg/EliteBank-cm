# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored — never commit it.

# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of frontend origins (used for CORS + CSRF).
# In production, set this to your Vercel URL: https://elite-bank.vercel.app
FRONTEND_URL=http://localhost:4200

# ── Database (Render auto-injects DATABASE_URL when linked to a Postgres) ─────
# Local dev defaults to SQLite if DATABASE_URL is empty.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Mobile-money gateway (NotchPay) ───────────────────────────────────────────
# Leave empty for DEMO MODE — deposits/withdrawals complete instantly without
# calling the real gateway. Useful for local dev & grading.
NOTCHPAY_PUBLIC_KEY=
NOTCHPAY_CALLBACK_URL=http://localhost:8000/api/transactions/deposit/callback/

# ── SMS (Africa's Talking) ────────────────────────────────────────────────────
# Set AT_USERNAME=sandbox + AT_API_KEY=<your-sandbox-key> to send real SMS,
# or leave AT_API_KEY empty to log to console instead of sending.
AT_USERNAME=sandbox
AT_API_KEY=

# ── Cloudinary (avatar uploads) ───────────────────────────────────────────────
# Optional — without these, avatar upload will fail. Get free keys at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (defaults to console backend if EMAIL_HOST_USER is empty) ───────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Elite Bank <noreply@elite-bank.cm>

# ── Production-only security toggles (Render) ─────────────────────────────────
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# ── Other ─────────────────────────────────────────────────────────────────────
EXCHANGE_API_KEY=
